flowchart LR
  subgraph CICD[CI/CD]
    GHA[GitHub Actions\n(test/build/deploy)]
  end

  subgraph IaC[Infrastructure as Code]
    SETTINGS[Settings (non-secret)\n(Pydantic schema)]
    PULUMI[Pulumi (Python)\n(preview/apply)]
  end

  subgraph Repo[Git Repo (Text Source of Truth)]
    REGMETA[Registry metadata\n(JSON/YAML)]
    WFDEF[Workflow definitions\n(photo / lora / video)]
    PROV[Workflow provenance\n(source/license/date)]
  end

  subgraph DevUX[Developer UX]
    PY[Python workflow code]
    PJSON[Prompt JSON\n(ComfyUI API format)]
    UIJSON[UI Workflow JSON\n(ComfyUI UI import/export)]
    WFLIB[Workflow library\n(photo / lora / video)]
  end

  subgraph Core[ComfyCode Core]
    IR[Workflow IR\n(nodes/edges)]
    WF[Workflow builder\n(comfycode.workflow)]
    CONV[Converter\n(comfycode.converter)]
    EXP[Export\n(comfycode.export)]
    LAYOUT[Layout\n(comfycode.layout)]
    UIEXP[UI Export\n(comfycode.ui_export)]
  end

  subgraph Platform[AI Influencer Platform (Target)]
    AGENTS[Agents\nTuner / VariantPlanner\nQualityGate / LoRATrainer]
    REG[Artifact Registry\n(file-based metadata)]
    CHAR[Character + Clothing Repos\n(reference images + metadata)]
    DOCS[Auto Docs Generator\n(inventory → docs)]
  end

  subgraph Azure[Azure (Low-Cost Persistence)]
    BLOB[Azure Blob Storage\n(artifacts + images)]
    TABLE[Azure Table Storage\n(thin lookup index)]
  end

  subgraph Exec[Execution]
    CCLIENT[ComfyUIClient\n(REST + WebSocket)]
    COMFY[ComfyUI Server]
    GPU[GPU Provider\n(RunPod / other)]
  end

  WFDEF --> WFLIB
  PROV --> WFDEF
  WFLIB --> PY

  PJSON -->|parse| IR
  IR -->|emit| PJSON

  IR -->|layout| LAYOUT
  IR -->|emit| UIEXP --> UIJSON

  PJSON -->|JSON→Python| CONV --> PY

  PY -->|create_workflow()| EXP --> PJSON

  AGENTS -->|propose params| PY
  AGENTS -->|register artifacts| REG

  REGMETA --> REG

  REG --> BLOB
  REG --> TABLE
  CHAR --> BLOB
  CHAR --> TABLE

  DOCS --> REG
  DOCS --> WFLIB
  DOCS --> REGMETA

  GHA -->|runs| PULUMI
  SETTINGS --> PULUMI
  PULUMI -->|provisions| BLOB
  PULUMI -->|provisions| TABLE

  PJSON --> CCLIENT --> COMFY --> GPU
